WAHA_URL=https://waha.opsipintar.site
WAHA_SESSION=default
COINGECKO_API_KEY=x-cg-demo-api-key
PORT=3000

# WAHA Engine Configuration (default: WEBJS)
WHATSAPP_DEFAULT_ENGINE=WEBJS
WHATSAPP_WEBJS_PUPPETER_ARGS=--no-sandbox

# Security
WHATSAPP_HOOK_HMAC_KEY=  # Optional: HMAC secret for webhook verification

# Access Control - comma separated group IDs (leave empty for public)
# Example: ALLOWED_CHATS=123456789@g.us,987654321@g.us
ALLOWED_CHATS=
